<!--
  Turn Swath SubTree — RS planner plans optimal fwd/rev path to next swath start.

  geo_points are reversed so map_points[0] = next swath start (the turn goal).
  GridBased (ReedsSheppPlanner) plans a single multi-segment path from current
  robot pose to the swath start heading, FollowPath (RsPathController) executes it.

  turn_side (from field file via blackboard) constrains the RS planner to only
  curve toward the headland side — never into the crop.
-->
<root BTCPP_format="4" main_tree_to_execute="TurnSwath">
  <BehaviorTree ID="TurnSwath">
    <Sequence>

      <!-- Prepare: reverse geo_points so map_points[0] = next swath start -->
      <ReverseGeoPoints geo_points="{geo_points}"/>
      <ConvertGeoPoints geo_points="{geo_points}" map_points="{map_points}"/>
      <GetPoseFromPoses poses="{map_points}" pose="{turn_goal_pose}" index="0"/>

      <!-- Constrain RS planner to headland side, plan, then clear constraint -->
      <SetRsPlannerConstraints turn_side="{turn_side}" map_points="{map_points}"/>
      <ComputePathToPose goal="{turn_goal_pose}" path="{turn_path}"
                         planner_id="GridBased"
                         error_code_id="{turn_compute_error}"/>
      <ClearRsPlannerConstraints/>

      <FollowPath path="{turn_path}" controller_id="FollowPath"
                  goal_checker_id="arc_goal_checker"
                  error_code_id="{turn_follow_error}"/>

    </Sequence>
  </BehaviorTree>
</root>
