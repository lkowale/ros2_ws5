<!--
  Turn Swath SubTree

  After completing a swath: reverse geo_points, re-convert to map frame,
  then drive to the new swath start using the RS planner.

  Blackboard inputs/outputs:
    geo_points: vector<GeoPoint>      — reversed in place
    map_points: vector<PoseStamped>   — updated after conversion
-->
<root BTCPP_format="4" main_tree_to_execute="TurnSwath">
  <BehaviorTree ID="TurnSwath">
    <Sequence>
      <!-- Reverse geo_points so next swath goes the other direction -->
      <ReverseGeoPoints geo_points="{geo_points}"/>
      <!-- Re-convert to map frame (heading recalculated from new start→end) -->
      <ConvertGeoPoints geo_points="{geo_points}" map_points="{map_points}"/>
      <!-- Drive to new swath start using RS planner -->
      <GetPoseFromPoses poses="{map_points}" pose="{turn_goal_pose}" index="0"/>
      <ComputePathToPose goal="{turn_goal_pose}" path="{turn_path}"
                         planner_id="GridBased" error_code_id="{turn_compute_error}"/>
      <FollowPath path="{turn_path}" controller_id="FollowPath"
                  error_code_id="{turn_follow_error}"/>
    </Sequence>
  </BehaviorTree>
</root>
