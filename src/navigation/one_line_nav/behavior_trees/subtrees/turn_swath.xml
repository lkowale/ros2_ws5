<!--
  Turn Swath SubTree — headland turn as explicit arc segments

  After completing a swath (robot heading = swath bearing α):

    Seg 1: forward left arc  90°  radius=1.5m   (clear headland)
    Seg 2: reverse right arc 60°  radius=1.5m   (back into position)
    Seg 3: forward connecting arc (left, ~120°)  radius=1.5m
    Seg 4: DriveOnHeading 0.5m forward          (lead-in to swath start)

  Then reverses geo_points and re-converts so next SwathNav runs the return pass.

  Angles are in radians:
    90°  = 1.5708
    60°  = 1.0472
   120°  = 2.0944

  speed signs:  positive = forward,  negative = reverse
-->
<root BTCPP_format="4" main_tree_to_execute="TurnSwath">
  <BehaviorTree ID="TurnSwath">
    <Sequence>

      <!-- Seg 1: forward left 90° -->
      <DriveArc radius="1.5" angle="1.5708" speed="0.4" time_allowance="30.0"
                error_code_id="{turn_arc1_error}"/>

      <!-- Seg 2: reverse right 60° -->
      <DriveArc radius="1.5" angle="-1.0472" speed="-0.3" time_allowance="30.0"
                error_code_id="{turn_arc2_error}"/>

      <!-- Seg 3: forward left connecting arc ~120° -->
      <DriveArc radius="1.5" angle="2.0944" speed="0.4" time_allowance="30.0"
                error_code_id="{turn_arc3_error}"/>

      <!-- Seg 4: 0.5m lead-in straight -->
      <DriveOnHeading dist_to_travel="0.5" speed="0.4" time_allowance="10.0"
                      error_code_id="{turn_leadin_error}"/>

      <!-- Prepare next swath: reverse geo_points and re-convert to map frame -->
      <ReverseGeoPoints geo_points="{geo_points}"/>
      <ConvertGeoPoints geo_points="{geo_points}" map_points="{map_points}"/>

    </Sequence>
  </BehaviorTree>
</root>
