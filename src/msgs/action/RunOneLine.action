# Goal — navigate along a single line in map frame.
# Provide start/end as map-frame x/y, or field_name to load from file.
float64 start_x
float64 start_y
float64 start_yaw   # heading at start (rad ENU), used for swath direction
float64 end_x
float64 end_y
float64 end_yaw     # heading at end (rad ENU)
string field_name   # if set, load from {fields_directory}/{field_name}/line.json
string behavior_tree
---
uint16 error_code
uint16 NONE=0
uint16 CANCELLED=1
uint16 FAILED=2
---
float32 distance_traveled
float32 total_distance
