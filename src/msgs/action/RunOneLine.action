# Goal — navigate along a single line defined by WGS84 start/end points.
# Either provide start_point/end_point directly, or field_name to load from file.
geographic_msgs/GeoPoint start_point
geographic_msgs/GeoPoint end_point
string field_name   # if set, load from {fields_directory}/{field_name}/line.json
string behavior_tree
---
uint16 error_code
uint16 NONE=0
uint16 CANCELLED=1
uint16 FAILED=2
---
float32 distance_traveled
float32 total_distance
